{% comment %}
  VELLOR Capsule Drops Page
  Limited releases and one-time drops
{% endcomment %}

<section class="vellor-capsule">
  <!-- Hero with video background -->
  <div class="vellor-capsule__hero">
    <video class="vellor-capsule__hero-video" autoplay muted loop playsinline poster="{{ 'capsule-hero.jpg' | asset_url }}">
      <source src="{{ 'capsule-hero.mp4' | asset_url }}" type="video/mp4">
    </video>
    <div class="vellor-capsule__hero-overlay"></div>
    <div class="vellor-capsule__hero-content">
      <p class="vellor-capsule__label">Limited Releases</p>
      <h1 class="vellor-capsule__title">Capsule Drops</h1>
      <p class="vellor-capsule__subtitle">One-time releases. Limited quantities. Once they're gone, they're gone.</p>
    </div>
  </div>

  <!-- Current / Upcoming with image -->
  <div class="vellor-capsule__current">
    <div class="vellor-capsule__current-grid">
      <div class="vellor-capsule__current-image">
        <img src="{{ 'capsule-hallun.jpg' | asset_url }}" alt="Hallun Grey Capsule" loading="lazy">
      </div>
      <div class="vellor-capsule__current-inner">
        <p class="vellor-capsule__label" style="color: #999;">Current Drop — Hallun Grey</p>
        <h2 class="vellor-capsule__heading">Nothing drops without intention.</h2>
        <p class="vellor-capsule__text">Each capsule is a small collection designed around a single idea. Limited pieces, limited time. When it's done, we move on.</p>
      </div>
    </div>
  </div>

  <!-- Soft Grey gallery -->
  <div class="vellor-capsule__gallery">
    <div class="vellor-capsule__gallery-inner">
      <p class="vellor-capsule__label" style="color: rgba(242,242,242,0.3);">Next Drop — Soft Grey</p>
      <div class="vellor-capsule__gallery-grid">
        <img src="{{ 'capsule-soft-1.jpg' | asset_url }}" alt="Soft Grey Capsule" loading="lazy">
        <img src="{{ 'capsule-soft-2.jpg' | asset_url }}" alt="Soft Grey Capsule" loading="lazy">
      </div>
    </div>
  </div>

  <!-- How It Works -->
  <div class="vellor-capsule__how">
    <div class="vellor-capsule__how-inner">
      <p class="vellor-capsule__label" style="color: rgba(242,242,242,0.15);">How Capsule Works</p>
      <h2 class="vellor-capsule__how-heading">Small runs. No restocks.</h2>
      <div class="vellor-capsule__steps">
        <div class="vellor-capsule__step">
          <span class="vellor-capsule__step-num">01</span>
          <h3 class="vellor-capsule__step-title">We design it.</h3>
          <p class="vellor-capsule__step-text">Each capsule starts with a single concept &mdash; a color, a mood, a moment. We design 2-4 pieces around that idea. Nothing extra.</p>
        </div>
        <div class="vellor-capsule__step">
          <span class="vellor-capsule__step-num">02</span>
          <h3 class="vellor-capsule__step-title">We make it.</h3>
          <p class="vellor-capsule__step-text">Small production runs. Same quality as our core collection &mdash; heavyweight fleece, garment-dyed, tonal V embroidery. Just fewer of them.</p>
        </div>
        <div class="vellor-capsule__step">
          <span class="vellor-capsule__step-num">03</span>
          <h3 class="vellor-capsule__step-title">We drop it.</h3>
          <p class="vellor-capsule__step-text">You get notified. You have a window. When it sells out, it doesn't come back. If you miss it, you miss it.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="vellor-capsule__cta">
    <h2 class="vellor-capsule__heading">Don't miss the next drop.</h2>
    <p class="vellor-capsule__text">Sign up and we'll let you know before anyone else.</p>
    <a href="/collections/all" class="vellor-capsule__link">Shop Core Collection</a>
  </div>
</section>

<style>
  .vellor-capsule__hero {
    position: relative;
    background: #0A0A0A;
    padding: 10rem 2rem 8rem;
    text-align: center;
    overflow: hidden;
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vellor-capsule__hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.55;
    z-index: 0;
  }
  .vellor-capsule__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(10,10,10,0.4) 0%, rgba(10,10,10,0.2) 50%, rgba(10,10,10,0.7) 100%);
    z-index: 1;
  }
  .vellor-capsule__hero-content {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .vellor-capsule__title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2.5rem, 5vw, 5rem);
    font-weight: 300;
    color: #F2F2F2;
    margin: 0;
    letter-spacing: 0.05em;
  }
  .vellor-capsule__subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: rgba(242,242,242,0.25);
    margin-top: 1.5rem;
    max-width: 400px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.7;
  }
  .vellor-capsule__label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(242,242,242,0.15);
    margin-bottom: 1.5rem;
  }
  .vellor-capsule__current {
    padding: 5rem 2rem;
    background: #F2F2F2;
  }
  .vellor-capsule__current-grid {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 769px) {
    .vellor-capsule__current-grid {
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
    }
  }
  .vellor-capsule__current-image {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: #e0e0e0;
  }
  .vellor-capsule__current-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .vellor-capsule__current-inner { text-align: left; }
  @media (max-width: 768px) {
    .vellor-capsule__current-inner { text-align: center; }
  }

  /* Capsule gallery (Soft Grey next drop) */
  .vellor-capsule__gallery {
    background: #0A0A0A;
    padding: 5rem 1.5rem;
  }
  @media (min-width: 769px) {
    .vellor-capsule__gallery { padding: 6rem 3rem; }
  }
  .vellor-capsule__gallery-inner {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }
  .vellor-capsule__gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }
  @media (min-width: 769px) {
    .vellor-capsule__gallery-grid {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }
  .vellor-capsule__gallery-grid img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    display: block;
  }
  .vellor-capsule__heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 300;
    color: #1C1C1C;
    margin: 0 0 1rem;
  }
  .vellor-capsule__text {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #999;
    line-height: 1.8;
  }
  .vellor-capsule__how {
    background: #0A0A0A;
    padding: 5rem 2rem;
  }
  @media (min-width: 769px) { .vellor-capsule__how { padding: 7rem 3rem; } }
  .vellor-capsule__how-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
  .vellor-capsule__how-heading {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-weight: 300;
    color: #F2F2F2;
    margin: 0 0 3rem;
  }
  .vellor-capsule__steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  @media (min-width: 769px) { .vellor-capsule__steps { grid-template-columns: repeat(3, 1fr); gap: 3rem; } }
  .vellor-capsule__step { text-align: center; }
  .vellor-capsule__step-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 0.8rem;
    color: #999;
    letter-spacing: 0.1em;
    display: block;
    margin-bottom: 1rem;
  }
  .vellor-capsule__step-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    color: #F2F2F2;
    margin: 0 0 0.75rem;
  }
  .vellor-capsule__step-text {
    font-family: 'Inter', sans-serif;
    font-size: 0.8rem;
    color: #999;
    line-height: 1.7;
    max-width: 300px;
    margin: 0 auto;
  }
  .vellor-capsule__cta {
    padding: 5rem 2rem;
    text-align: center;
    background: #F2F2F2;
  }
  .vellor-capsule__link {
    display: inline-block;
    margin-top: 1.5rem;
    font-family: 'Inter', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #1C1C1C;
    text-decoration: none;
    border-bottom: 1px solid #1C1C1C;
    padding-bottom: 2px;
  }
</style>

{% schema %}
{
  "name": "Capsule Page",
  "tag": "section",
  "settings": [],
  "presets": [{ "name": "Capsule Page", "category": "VELLOR" }]
}
{% endschema %}
