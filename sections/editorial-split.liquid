{% comment %}
  VELLOR Editorial Split Section
  Two-column layout: image left, text right
{% endcomment %}

<section id="editorial-split-{{ section.id }}" class="vellor-editorial">
  <div class="vellor-editorial__grid">
    <div class="vellor-editorial__image-col">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 900 }} 900w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
          class="vellor-editorial__image"
        >
      {% else %}
        <div class="vellor-editorial__placeholder">
          {{ 'lifestyle-1' | placeholder_svg_tag: 'vellor-editorial__placeholder-svg' }}
        </div>
      {% endif %}
    </div>

    <div class="vellor-editorial__text-col">
      <div class="vellor-editorial__text-inner">
        {% if section.settings.label != blank %}
          <span class="vellor-editorial__label">{{ section.settings.label }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vellor-editorial__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="vellor-editorial__description">{{ section.settings.description }}</div>
        {% endif %}

        {% if section.settings.cta_text != blank %}
          <a href="{{ section.settings.cta_url | default: '#' }}" class="vellor-editorial__cta">
            {{ section.settings.cta_text }}
            <span class="vellor-editorial__cta-line"></span>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #editorial-split-{{ section.id }} {
    background-color: #F2F2F2;
    color: #1C1C1C;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 600px;
  }

  @media (min-width: 769px) {
    #editorial-split-{{ section.id }} .vellor-editorial__grid {
      grid-template-columns: 1fr 1fr;
      min-height: 80vh;
    }
  }

  #editorial-split-{{ section.id }} .vellor-editorial__image-col {
    position: relative;
    overflow: hidden;
    min-height: 400px;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__placeholder {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__placeholder-svg {
    width: 60%;
    opacity: 0.3;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__text-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
  }

  @media (min-width: 769px) {
    #editorial-split-{{ section.id }} .vellor-editorial__text-col {
      padding: 4rem;
    }
  }

  #editorial-split-{{ section.id }} .vellor-editorial__text-inner {
    max-width: 480px;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__label {
    display: block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999999;
    margin-bottom: 1.5rem;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 1.5rem;
    color: #1C1C1C;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__description {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #999999;
    margin-bottom: 2rem;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__cta {
    display: inline-block;
    position: relative;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1C1C1C;
    text-decoration: none;
    padding-bottom: 4px;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__cta-line {
    display: block;
    width: 100%;
    height: 1px;
    background-color: #1C1C1C;
    margin-top: 4px;
    transition: width 0.3s ease;
  }

  #editorial-split-{{ section.id }} .vellor-editorial__cta:hover .vellor-editorial__cta-line {
    width: 50%;
  }
</style>

{% schema %}
{
  "name": "Editorial Split",
  "tag": "section",
  "class": "vellor-section-editorial",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Women's Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Refined Essentials for the Modern Woman"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Timeless silhouettes crafted from premium fabrics. Each piece is designed to move with you, season after season.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Editorial Split",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
