{% comment %}
  VELLOR About Content Section
  Multi-part about page: What We Are, The Standard (3 pillars), The Collection, Contact, CTA
{% endcomment %}

<section id="about-content-{{ section.id }}" class="vellor-about">

  <!-- What We Are -->
  <div class="vellor-about__who">
    <div class="vellor-about__who-grid">
      <div class="vellor-about__who-image-col">
        {% if section.settings.who_image %}
          <img
            src="{{ section.settings.who_image | image_url: width: 1000 }}"
            alt="{{ section.settings.who_heading }}"
            class="vellor-about__who-image"
            loading="lazy"
          >
        {% else %}
          <div class="vellor-about__who-placeholder">
            {{ 'lifestyle-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      <div class="vellor-about__who-text-col">
        <div class="vellor-about__who-text-inner">
          {% if section.settings.who_label != blank %}
            <span class="vellor-about__label">{{ section.settings.who_label }}</span>
          {% endif %}
          {% if section.settings.who_heading != blank %}
            <h2 class="vellor-about__heading">{{ section.settings.who_heading }}</h2>
          {% endif %}
          {% if section.settings.who_text != blank %}
            <div class="vellor-about__text">{{ section.settings.who_text }}</div>
          {% endif %}
        </div>
      </div>
    </div>
  </div>

  <!-- The Standard (3 Pillars) -->
  <div class="vellor-about__pillars">
    <div class="vellor-about__pillars-inner">
      {% if section.settings.pillars_heading != blank %}
        <h2 class="vellor-about__pillars-heading">{{ section.settings.pillars_heading }}</h2>
      {% endif %}

      <div class="vellor-about__pillars-grid">
        {% for block in section.blocks %}
          {% if block.type == 'pillar' %}
            <div class="vellor-about__pillar" {{ block.shopify_attributes }}>
              <span class="vellor-about__pillar-number">0{{ forloop.index }}</span>
              <h3 class="vellor-about__pillar-title">{{ block.settings.title }}</h3>
              <p class="vellor-about__pillar-text">{{ block.settings.text }}</p>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>

  <!-- The Collection Description -->
  <div class="vellor-about__collection-desc">
    <div class="vellor-about__collection-desc-inner">
      {% if section.settings.collection_heading != blank %}
        <h2 class="vellor-about__heading">{{ section.settings.collection_heading }}</h2>
      {% endif %}
      {% if section.settings.collection_text != blank %}
        <div class="vellor-about__text vellor-about__text--centered">{{ section.settings.collection_text }}</div>
      {% endif %}
      {% if section.settings.collection_cta_text != blank %}
        <a href="{{ section.settings.collection_cta_url | default: '/collections/all' }}" class="vellor-about__cta-link">
          {{ section.settings.collection_cta_text }}
          <span class="vellor-about__cta-line"></span>
        </a>
      {% endif %}
    </div>
  </div>

  <!-- Contact Info -->
  <div class="vellor-about__contact">
    <div class="vellor-about__contact-inner">
      {% if section.settings.contact_heading != blank %}
        <h2 class="vellor-about__heading">{{ section.settings.contact_heading }}</h2>
      {% endif %}
      {% if section.settings.contact_email != blank %}
        <a href="mailto:{{ section.settings.contact_email }}" class="vellor-about__contact-email">{{ section.settings.contact_email }}</a>
      {% endif %}
      {% if section.settings.contact_text != blank %}
        <p class="vellor-about__contact-text">{{ section.settings.contact_text }}</p>
      {% endif %}
    </div>
  </div>

  <!-- CTA -->
  <div class="vellor-about__bottom-cta">
    <div class="vellor-about__bottom-cta-inner">
      {% if section.settings.cta_heading != blank %}
        <h2 class="vellor-about__cta-heading">{{ section.settings.cta_heading }}</h2>
      {% endif %}
      {% if section.settings.cta_button_text != blank %}
        <a href="{{ section.settings.cta_button_url | default: '/collections/all' }}" class="vellor-about__cta-button">
          {{ section.settings.cta_button_text }}
        </a>
      {% endif %}
    </div>
  </div>

</section>

<style>
  #about-content-{{ section.id }} {
    color: #1C1C1C;
  }

  #about-content-{{ section.id }} .vellor-about__label {
    display: block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999999;
    margin-bottom: 1.5rem;
  }

  #about-content-{{ section.id }} .vellor-about__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 300;
    line-height: 1.2;
    margin: 0 0 1.25rem;
  }

  #about-content-{{ section.id }} .vellor-about__text {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.9rem;
    line-height: 1.8;
    color: #999999;
  }

  #about-content-{{ section.id }} .vellor-about__text p {
    margin: 0 0 1rem;
  }

  /* What We Are */
  #about-content-{{ section.id }} .vellor-about__who {
    background-color: #F2F2F2;
  }

  #about-content-{{ section.id }} .vellor-about__who-grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 500px;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__who-grid {
      grid-template-columns: 1fr 1fr;
      min-height: 70vh;
    }
  }

  #about-content-{{ section.id }} .vellor-about__who-image-col {
    overflow: hidden;
    min-height: 350px;
  }

  #about-content-{{ section.id }} .vellor-about__who-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #about-content-{{ section.id }} .vellor-about__who-placeholder {
    width: 100%;
    height: 100%;
    background-color: #e0e0e0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #about-content-{{ section.id }} .vellor-about__who-text-col {
    display: flex;
    align-items: center;
    padding: 3rem 2rem;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__who-text-col {
      padding: 4rem;
    }
  }

  #about-content-{{ section.id }} .vellor-about__who-text-inner {
    max-width: 480px;
  }

  /* Pillars */
  #about-content-{{ section.id }} .vellor-about__pillars {
    background-color: #0A0A0A;
    color: #F2F2F2;
    padding: 5rem 2rem;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__pillars {
      padding: 7rem 3rem;
    }
  }

  #about-content-{{ section.id }} .vellor-about__pillars-inner {
    max-width: 1200px;
    margin: 0 auto;
  }

  #about-content-{{ section.id }} .vellor-about__pillars-heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 300;
    text-align: center;
    color: #F2F2F2;
    margin: 0 0 4rem;
  }

  #about-content-{{ section.id }} .vellor-about__pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__pillars-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 3rem;
    }
  }

  #about-content-{{ section.id }} .vellor-about__pillar {
    text-align: center;
  }

  #about-content-{{ section.id }} .vellor-about__pillar-number {
    display: block;
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 0.9rem;
    color: #999999;
    margin-bottom: 1rem;
    letter-spacing: 0.1em;
  }

  #about-content-{{ section.id }} .vellor-about__pillar-title {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: #F2F2F2;
    margin: 0 0 1rem;
  }

  #about-content-{{ section.id }} .vellor-about__pillar-text {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #999999;
    margin: 0;
    max-width: 320px;
    margin-left: auto;
    margin-right: auto;
  }

  /* Collection Description */
  #about-content-{{ section.id }} .vellor-about__collection-desc {
    background-color: #F2F2F2;
    padding: 5rem 2rem;
    text-align: center;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__collection-desc {
      padding: 7rem 3rem;
    }
  }

  #about-content-{{ section.id }} .vellor-about__collection-desc-inner {
    max-width: 650px;
    margin: 0 auto;
  }

  #about-content-{{ section.id }} .vellor-about__text--centered {
    text-align: center;
  }

  #about-content-{{ section.id }} .vellor-about__cta-link {
    display: inline-block;
    margin-top: 2rem;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1C1C1C;
    text-decoration: none;
  }

  #about-content-{{ section.id }} .vellor-about__cta-line {
    display: block;
    width: 100%;
    height: 1px;
    background-color: #1C1C1C;
    margin-top: 4px;
    transition: width 0.3s ease;
  }

  #about-content-{{ section.id }} .vellor-about__cta-link:hover .vellor-about__cta-line {
    width: 50%;
  }

  /* Contact */
  #about-content-{{ section.id }} .vellor-about__contact {
    background-color: #F2F2F2;
    padding: 0 2rem 5rem;
    text-align: center;
    border-top: 1px solid #e0e0e0;
    padding-top: 5rem;
  }

  #about-content-{{ section.id }} .vellor-about__contact-inner {
    max-width: 500px;
    margin: 0 auto;
  }

  #about-content-{{ section.id }} .vellor-about__contact-email {
    display: block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.9rem;
    color: #1C1C1C;
    text-decoration: none;
    margin-bottom: 0.75rem;
    transition: opacity 0.3s ease;
  }

  #about-content-{{ section.id }} .vellor-about__contact-email:hover {
    opacity: 0.6;
  }

  #about-content-{{ section.id }} .vellor-about__contact-text {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    color: #999999;
    line-height: 1.6;
  }

  /* Bottom CTA */
  #about-content-{{ section.id }} .vellor-about__bottom-cta {
    background-color: #0A0A0A;
    padding: 5rem 2rem;
    text-align: center;
  }

  @media (min-width: 769px) {
    #about-content-{{ section.id }} .vellor-about__bottom-cta {
      padding: 7rem 3rem;
    }
  }

  #about-content-{{ section.id }} .vellor-about__cta-heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(1.75rem, 3.5vw, 3rem);
    font-weight: 300;
    color: #F2F2F2;
    margin: 0 0 2rem;
  }

  #about-content-{{ section.id }} .vellor-about__cta-button {
    display: inline-block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #0A0A0A;
    background-color: #F2F2F2;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  #about-content-{{ section.id }} .vellor-about__cta-button:hover {
    background-color: transparent;
    color: #F2F2F2;
    outline: 1px solid #F2F2F2;
    outline-offset: -1px;
  }
</style>

{% schema %}
{
  "name": "About Content",
  "tag": "section",
  "class": "vellor-section-about-content",
  "settings": [
    {
      "type": "header",
      "content": "What We Are"
    },
    {
      "type": "image_picker",
      "id": "who_image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "who_label",
      "label": "Label",
      "default": "About VELLOR"
    },
    {
      "type": "text",
      "id": "who_heading",
      "label": "Heading",
      "default": "What We Are"
    },
    {
      "type": "richtext",
      "id": "who_text",
      "label": "Text",
      "default": "<p>VELLOR is a luxury essentials brand built on the belief that everyday clothing should be extraordinary. We source the finest materials and work with master artisans to create pieces that transcend trends.</p>"
    },
    {
      "type": "header",
      "content": "The Standard (Pillars)"
    },
    {
      "type": "text",
      "id": "pillars_heading",
      "label": "Pillars Heading",
      "default": "The Standard"
    },
    {
      "type": "header",
      "content": "The Collection"
    },
    {
      "type": "text",
      "id": "collection_heading",
      "label": "Collection Heading",
      "default": "The Collection"
    },
    {
      "type": "richtext",
      "id": "collection_text",
      "label": "Collection Text",
      "default": "<p>Every VELLOR piece is designed to be a wardrobe staple. From our signature tees to structured outerwear, each garment is crafted to stand the test of time.</p>"
    },
    {
      "type": "text",
      "id": "collection_cta_text",
      "label": "Collection CTA Text",
      "default": "Shop the Collection"
    },
    {
      "type": "url",
      "id": "collection_cta_url",
      "label": "Collection CTA URL"
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact Heading",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Email",
      "default": "hello@vellor.com"
    },
    {
      "type": "text",
      "id": "contact_text",
      "label": "Contact Text",
      "default": "We respond within 24 hours, Monday through Friday."
    },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "CTA Heading",
      "default": "Experience the Difference"
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "CTA Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "CTA Button URL"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Pillar",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Premium Materials"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "We source only the finest fabrics from mills around the world, ensuring every piece feels as exceptional as it looks."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "About Content",
      "category": "VELLOR",
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Premium Materials",
            "text": "We source only the finest fabrics from mills around the world, ensuring every piece feels as exceptional as it looks."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Timeless Design",
            "text": "Our designs transcend seasons and trends. Each silhouette is refined to be relevant today and for years to come."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Artisan Craftsmanship",
            "text": "Every garment is constructed with meticulous attention to detail by skilled artisans who share our obsession with quality."
          }
        }
      ]
    }
  ]
}
{% endschema %}
