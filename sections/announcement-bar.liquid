{% comment %}
  VELLOR Announcement Bar Section
  Optional top bar with customizable message and link
{% endcomment %}

{% if section.settings.show_bar %}
  <section id="announcement-bar-{{ section.id }}" class="vellor-announcement" role="banner">
    <div class="vellor-announcement__inner">
      {% if section.settings.link_url != blank %}
        <a href="{{ section.settings.link_url }}" class="vellor-announcement__link">
          {{ section.settings.text | default: 'Free shipping on orders over $150' }}
        </a>
      {% else %}
        <p class="vellor-announcement__text">
          {{ section.settings.text | default: 'Free shipping on orders over $150' }}
        </p>
      {% endif %}
    </div>
  </section>
{% endif %}

<style>
  #announcement-bar-{{ section.id }} {
    background-color: {{ section.settings.bg_color | default: '#0A0A0A' }};
    padding: 0.6rem 1rem;
    text-align: center;
  }

  #announcement-bar-{{ section.id }} .vellor-announcement__inner {
    max-width: 1400px;
    margin: 0 auto;
  }

  #announcement-bar-{{ section.id }} .vellor-announcement__text,
  #announcement-bar-{{ section.id }} .vellor-announcement__link {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.65rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: {{ section.settings.text_color | default: '#F2F2F2' }};
    margin: 0;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  #announcement-bar-{{ section.id }} .vellor-announcement__link:hover {
    opacity: 0.7;
  }
</style>

{% schema %}
{
  "name": "Announcement Bar",
  "tag": "section",
  "class": "vellor-section-announcement",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_bar",
      "label": "Show Announcement Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "text",
      "label": "Announcement Text",
      "default": "Free shipping on orders over $150"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#F2F2F2"
    }
  ],
  "presets": [
    {
      "name": "Announcement Bar",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
