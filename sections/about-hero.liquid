{% comment %}
  VELLOR About Hero Section
  Video hero with heading and subtitle for the About page
{% endcomment %}

<section id="about-hero-{{ section.id }}" class="vellor-about-hero">
  <div class="vellor-about-hero__media">
    {% assign video_src = section.settings.video_url %}
    {% if video_src == blank %}
      {% assign video_src = 'model-sweats.mp4' | asset_url %}
    {% endif %}
    <video
      class="vellor-about-hero__video"
      autoplay
      muted
      loop
      playsinline
      poster="{{ 'model-hero.png' | asset_url }}"
    >
      <source src="{{ video_src }}" type="video/mp4">
    </video>
    <div class="vellor-about-hero__overlay"></div>
  </div>

  <div class="vellor-about-hero__content">
    {% if section.settings.heading != blank %}
      <h1 class="vellor-about-hero__heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="vellor-about-hero__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>
</section>

<style>
  #about-hero-{{ section.id }} {
    position: relative;
    width: 100%;
    height: 80vh;
    min-height: 500px;
    overflow: hidden;
    background-color: #0A0A0A;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__media {
    position: absolute;
    inset: 0;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__video,
  #about-hero-{{ section.id }} .vellor-about-hero__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 20%;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.35) 0%,
      rgba(0, 0, 0, 0.15) 40%,
      rgba(0, 0, 0, 0.15) 60%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 2rem;
    text-align: center;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(3rem, 9vw, 9rem);
    font-weight: 300;
    letter-spacing: 0.25em;
    color: #F2F2F2;
    margin: 0;
    text-transform: uppercase;
    line-height: 1;
  }

  #about-hero-{{ section.id }} .vellor-about-hero__subtitle {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: clamp(0.75rem, 1.5vw, 0.9rem);
    font-weight: 300;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(242, 242, 242, 0.7);
    margin-top: 1.5rem;
  }
</style>

{% schema %}
{
  "name": "About Hero",
  "tag": "section",
  "class": "vellor-section-about-hero",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster / Fallback Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "VELLOR"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The Standard for Everyday Luxury"
    }
  ],
  "presets": [
    {
      "name": "About Hero",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
