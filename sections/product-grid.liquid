{% comment %}
  VELLOR Product Grid Section
  Collection-based product grid with hover effects and badges
{% endcomment %}

{%- assign collection_handle = section.settings.collection | default: 'all' -%}
{%- assign collection = collections[collection_handle] -%}
{%- assign limit = section.settings.products_to_show | default: 6 -%}

<section id="product-grid-{{ section.id }}" class="vellor-product-grid">
  <div class="vellor-product-grid__container">
    {% if section.settings.heading != blank %}
      <h2 class="vellor-product-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="vellor-product-grid__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="vellor-product-grid__grid">
      {%- assign shown_count = 0 -%}
      {% for product in collection.products %}
        {%- if shown_count >= limit -%}{%- break -%}{%- endif -%}
        {%- unless product.featured_image -%}{%- continue -%}{%- endunless -%}
        {%- assign shown_count = shown_count | plus: 1 -%}
        <a href="{{ product.url }}" class="vellor-product-card">
          <div class="vellor-product-card__image-wrap">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                        {{ product.featured_image | image_url: width: 600 }} 600w,
                        {{ product.featured_image | image_url: width: 800 }} 800w"
                sizes="(max-width: 768px) 50vw, 33vw"
                alt="{{ product.featured_image.alt | default: product.title }}"
                loading="lazy"
                class="vellor-product-card__image"
              >
            {% else %}
              <div class="vellor-product-card__no-image">
