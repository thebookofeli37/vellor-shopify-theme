{% comment %}
  VELLOR Product Grid Section
  Collection-based product grid with hover effects and badges
{% endcomment %}

{%- assign collection_handle = section.settings.collection | default: 'all' -%}
{%- assign collection = collections[collection_handle] -%}
{%- assign limit = section.settings.products_to_show | default: 6 -%}

<section id="product-grid-{{ section.id }}" class="vellor-product-grid">
  <div class="vellor-product-grid__container">
    {% if section.settings.heading != blank %}
      <h2 class="vellor-product-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="vellor-product-grid__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="vellor-product-grid__grid">
      {% for product in collection.products limit: limit %}
        <a href="{{ product.url }}" class="vellor-product-card">
          <div class="vellor-product-card__image-wrap">
            {% if product.featured_image %}
              <img
                src="{{ product.featured_image | image_url: width: 800 }}"
                srcset="{{ product.featured_image | image_url: width: 400 }} 400w,
                        {{ product.featured_image | image_url: width: 600 }} 600w,
                        {{ product.featured_image | image_url: width: 800 }} 800w"
                sizes="(max-width: 768px) 50vw, 33vw"
                alt="{{ product.featured_image.alt | default: product.title }}"
                loading="lazy"
                class="vellor-product-card__image"
              >
            {% else %}
              <div class="vellor-product-card__no-image">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}

            {% if product.available == false %}
              <span class="vellor-product-card__badge vellor-product-card__badge--soldout">Sold Out</span>
            {% elsif product.compare_at_price > product.price %}
              <span class="vellor-product-card__badge vellor-product-card__badge--sale">Sale</span>
            {% elsif product.tags contains 'new' %}
              <span class="vellor-product-card__badge">New</span>
            {% endif %}
          </div>

          <div class="vellor-product-card__info">
            <h3 class="vellor-product-card__title">{{ product.title }}</h3>
            <div class="vellor-product-card__price">
              {% if product.compare_at_price > product.price %}
                <span class="vellor-product-card__price-compare">{{ product.compare_at_price | money }}</span>
              {% endif %}
              <span class="vellor-product-card__price-current">{{ product.price | money }}</span>
            </div>
          </div>
        </a>
      {% else %}
        {% for i in (1..limit) %}
          <div class="vellor-product-card vellor-product-card--placeholder">
            <div class="vellor-product-card__image-wrap">
              {{ 'product-1' | placeholder_svg_tag: 'vellor-product-card__placeholder-svg' }}
            </div>
            <div class="vellor-product-card__info">
              <h3 class="vellor-product-card__title">Product Title</h3>
              <div class="vellor-product-card__price">
                <span class="vellor-product-card__price-current">$0.00</span>
              </div>
            </div>
          </div>
        {% endfor %}
      {% endfor %}
    </div>

    {% if section.settings.cta_text != blank %}
      <div class="vellor-product-grid__cta-wrap">
        <a href="{{ section.settings.cta_url | default: collections[collection_handle].url }}" class="vellor-product-grid__cta">
          {{ section.settings.cta_text }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #product-grid-{{ section.id }} {
    background-color: #F2F2F2;
    padding: 4rem 1.5rem;
    color: #1C1C1C;
  }

  @media (min-width: 769px) {
    #product-grid-{{ section.id }} {
      padding: 6rem 3rem;
    }
  }

  #product-grid-{{ section.id }} .vellor-product-grid__container {
    max-width: 1400px;
    margin: 0 auto;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300;
    text-align: center;
    margin: 0 0 0.75rem;
    color: #1C1C1C;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__subheading {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.85rem;
    color: #999999;
    text-align: center;
    margin: 0 0 3rem;
    letter-spacing: 0.03em;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (min-width: 769px) {
    #product-grid-{{ section.id }} .vellor-product-grid__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  #product-grid-{{ section.id }} .vellor-product-card {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  #product-grid-{{ section.id }} .vellor-product-card__image-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background-color: #e8e8e8;
  }

  #product-grid-{{ section.id }} .vellor-product-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  #product-grid-{{ section.id }} .vellor-product-card:hover .vellor-product-card__image {
    transform: scale(1.05);
  }

  #product-grid-{{ section.id }} .vellor-product-card__badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.65rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 0.3rem 0.6rem;
    background-color: #1C1C1C;
    color: #F2F2F2;
  }

  #product-grid-{{ section.id }} .vellor-product-card__badge--soldout {
    background-color: #999999;
  }

  #product-grid-{{ section.id }} .vellor-product-card__badge--sale {
    background-color: #8B0000;
  }

  #product-grid-{{ section.id }} .vellor-product-card__info {
    padding: 1rem 0;
  }

  #product-grid-{{ section.id }} .vellor-product-card__title {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin: 0 0 0.35rem;
    color: #1C1C1C;
  }

  #product-grid-{{ section.id }} .vellor-product-card__price {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    color: #999999;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  #product-grid-{{ section.id }} .vellor-product-card__price-compare {
    text-decoration: line-through;
    color: #bbb;
  }

  #product-grid-{{ section.id }} .vellor-product-card__no-image,
  #product-grid-{{ section.id }} .vellor-product-card__placeholder-svg {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #e8e8e8;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__cta-wrap {
    text-align: center;
    margin-top: 3rem;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__cta {
    display: inline-block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #1C1C1C;
    text-decoration: none;
    border-bottom: 1px solid #1C1C1C;
    padding-bottom: 4px;
    transition: opacity 0.3s ease;
  }

  #product-grid-{{ section.id }} .vellor-product-grid__cta:hover {
    opacity: 0.6;
  }
</style>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "class": "vellor-section-product-grid",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Timeless pieces crafted for everyday luxury"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "View All"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Product Grid",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
