{% comment %}
  VELLOR Affiliate CTA Section
  Partner / affiliate program call-to-action
{% endcomment %}

<section id="affiliate-cta-{{ section.id }}" class="vellor-affiliate">
  <div class="vellor-affiliate__container">
    {% if section.settings.label != blank %}
      <span class="vellor-affiliate__label">{{ section.settings.label }}</span>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="vellor-affiliate__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description != blank %}
      <p class="vellor-affiliate__description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_url | default: '#' }}" class="vellor-affiliate__cta">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</section>

<style>
  #affiliate-cta-{{ section.id }} {
    background-color: #0A0A0A;
    color: #F2F2F2;
    padding: 5rem 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  @media (min-width: 769px) {
    #affiliate-cta-{{ section.id }} {
      padding: 7rem 3rem;
    }
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__container {
    max-width: 600px;
    margin: 0 auto;
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__label {
    display: block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999999;
    margin-bottom: 1.5rem;
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    font-weight: 300;
    line-height: 1.2;
    margin: 0 0 1.25rem;
    color: #F2F2F2;
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__description {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.85rem;
    line-height: 1.7;
    color: #999999;
    margin: 0 0 2rem;
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__cta {
    display: inline-block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #0A0A0A;
    background-color: #F2F2F2;
    padding: 0.9rem 2.5rem;
    text-decoration: none;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  #affiliate-cta-{{ section.id }} .vellor-affiliate__cta:hover {
    background-color: transparent;
    color: #F2F2F2;
    outline: 1px solid #F2F2F2;
    outline-offset: -1px;
  }
</style>

{% schema %}
{
  "name": "Affiliate CTA",
  "tag": "section",
  "class": "vellor-section-affiliate",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Partner With Us"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Become a VELLOR Affiliate"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "Join our network of tastemakers and earn commission on every referral. Apply to become a VELLOR partner."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "Affiliate CTA",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
