{% comment %}
  VELLOR Hero Video Section
  Full-screen video hero with gradient overlay and centered branding
{% endcomment %}

<section id="hero-video" class="vellor-hero" data-section-id="{{ section.id }}">
  <div class="vellor-hero__media">
    {% assign video_src = section.settings.video_url %}
    {% if video_src == blank %}
      {% assign video_src = 'model-blue.mp4' | asset_url %}
    {% endif %}
    <video
      class="vellor-hero__video"
      autoplay
      muted
      loop
      playsinline
      poster="{{ 'model-web.png' | asset_url }}"
    >
      <source src="{{ video_src }}" type="video/mp4">
    </video>
    <div class="vellor-hero__overlay"></div>
  </div>

  <div class="vellor-hero__content">
    <h1 class="vellor-hero__heading">{{ section.settings.heading | default: 'VELLOR' }}</h1>

    {% if section.settings.link_text != blank %}
      <a href="{{ section.settings.link_url | default: '#' }}" class="vellor-hero__link">
        {{ section.settings.link_text }}
        <span class="vellor-hero__link-arrow">&darr;</span>
      </a>
    {% endif %}
  </div>
</section>

<style>
  #hero-video {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 600px;
    overflow: hidden;
    background-color: #0A0A0A;
  }

  .vellor-hero__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .vellor-hero__video,
  .vellor-hero__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .vellor-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.3) 0%,
      transparent 40%,
      transparent 60%,
      rgba(0, 0, 0, 0.5) 100%
    );
    pointer-events: none;
  }

  .vellor-hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 2rem;
    text-align: center;
  }

  .vellor-hero__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(3.5rem, 10vw, 11rem);
    font-weight: 300;
    letter-spacing: 0.25em;
    color: #F2F2F2;
    margin: 0;
    text-transform: uppercase;
    line-height: 1;
  }

  .vellor-hero__link {
    position: absolute;
    bottom: 3rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.75rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #F2F2F2;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }

  .vellor-hero__link:hover {
    opacity: 0.7;
  }

  .vellor-hero__link-arrow {
    display: block;
    font-size: 1.25rem;
    animation: vellor-bounce 2s ease-in-out infinite;
  }

  @keyframes vellor-bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(6px); }
  }
</style>

{% schema %}
{
  "name": "Hero Video",
  "tag": "section",
  "class": "vellor-section-hero",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Direct link to an MP4 video file"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster / Fallback Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading Text",
      "default": "VELLOR"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link Text",
      "default": "Discover"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL"
    }
  ],
  "presets": [
    {
      "name": "Hero Video",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
