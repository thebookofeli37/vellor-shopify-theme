{% comment %}
  VELLOR Video Interlude Section
  Full-width cinematic video break with overlay text
{% endcomment %}

<section id="video-interlude-{{ section.id }}" class="vellor-interlude">
  <div class="vellor-interlude__media">
    {% if section.settings.video_url != blank %}
      <video
        class="vellor-interlude__video"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.poster_image %}
          poster="{{ section.settings.poster_image | image_url: width: 1920 }}"
        {% endif %}
      >
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% elsif section.settings.poster_image %}
      <img
        src="{{ section.settings.poster_image | image_url: width: 1920 }}"
        alt="{{ section.settings.heading }}"
        class="vellor-interlude__poster"
        loading="lazy"
      >
    {% endif %}
    <div class="vellor-interlude__overlay"></div>
  </div>

  <div class="vellor-interlude__content">
    {% if section.settings.heading != blank %}
      <h2 class="vellor-interlude__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subtext != blank %}
      <p class="vellor-interlude__subtext">{{ section.settings.subtext }}</p>
    {% endif %}
  </div>
</section>

<style>
  #video-interlude-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: 60vh;
    overflow: hidden;
    background-color: #0A0A0A;
  }

  @media (min-width: 769px) {
    #video-interlude-{{ section.id }} {
      min-height: 80vh;
    }
  }

  #video-interlude-{{ section.id }} .vellor-interlude__media {
    position: absolute;
    inset: 0;
  }

  #video-interlude-{{ section.id }} .vellor-interlude__video,
  #video-interlude-{{ section.id }} .vellor-interlude__poster {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  #video-interlude-{{ section.id }} .vellor-interlude__overlay {
    position: absolute;
    inset: 0;
    background-color: rgba(0, 0, 0, 0.45);
    pointer-events: none;
  }

  #video-interlude-{{ section.id }} .vellor-interlude__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: inherit;
    padding: 3rem 2rem;
    text-align: center;
  }

  #video-interlude-{{ section.id }} .vellor-interlude__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(1.75rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.2;
    color: #F2F2F2;
    margin: 0;
    max-width: 700px;
    letter-spacing: 0.02em;
  }

  #video-interlude-{{ section.id }} .vellor-interlude__subtext {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    color: #999999;
    margin-top: 1.5rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }
</style>

{% schema %}
{
  "name": "Video Interlude",
  "tag": "section",
  "class": "vellor-section-interlude",
  "settings": [
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (MP4)",
      "info": "Direct link to an MP4 video file"
    },
    {
      "type": "image_picker",
      "id": "poster_image",
      "label": "Poster / Fallback Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to be worn. Built to last."
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext"
    }
  ],
  "presets": [
    {
      "name": "Video Interlude",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
