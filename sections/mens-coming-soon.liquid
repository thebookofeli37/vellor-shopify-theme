{% comment %}
  VELLOR Men's Coming Soon Section
  Two-column: text left with email signup, image right, dark background
{% endcomment %}

<section id="mens-coming-soon-{{ section.id }}" class="vellor-coming-soon">
  <div class="vellor-coming-soon__grid">
    <div class="vellor-coming-soon__text-col">
      <div class="vellor-coming-soon__text-inner">
        {% if section.settings.label != blank %}
          <span class="vellor-coming-soon__label">{{ section.settings.label }}</span>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="vellor-coming-soon__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.description != blank %}
          <div class="vellor-coming-soon__description">{{ section.settings.description }}</div>
        {% endif %}

        <form class="vellor-coming-soon__form" action="/contact#mens-notify" method="post" accept-charset="UTF-8">
          <input type="hidden" name="form_type" value="customer">
          <input type="hidden" name="utf8" value="&#x2713;">
          <input type="hidden" name="contact[tags]" value="mens-notify">

          <div class="vellor-coming-soon__form-row">
            <input
              type="email"
              name="contact[email]"
              class="vellor-coming-soon__input"
              placeholder="{{ section.settings.placeholder_text | default: 'Enter your email' }}"
              required
              aria-label="Email address"
            >
            <button type="submit" class="vellor-coming-soon__button">
              {{ section.settings.button_text | default: 'Notify Me' }}
            </button>
          </div>
        </form>
      </div>
    </div>

    <div class="vellor-coming-soon__image-col">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          srcset="{{ section.settings.image | image_url: width: 600 }} 600w,
                  {{ section.settings.image | image_url: width: 900 }} 900w,
                  {{ section.settings.image | image_url: width: 1200 }} 1200w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          loading="lazy"
          class="vellor-coming-soon__image"
        >
      {% else %}
        <img
          src="{{ 'undone-hoodie.jpg' | asset_url }}"
          alt="VELLOR UNDONE hoodie"
          loading="lazy"
          class="vellor-coming-soon__image"
          style="opacity: 0.7;"
        >
      {% endif %}
    </div>
  </div>
</section>

<style>
  #mens-coming-soon-{{ section.id }} {
    background-color: #0A0A0A;
    color: #F2F2F2;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__grid {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 500px;
  }

  @media (min-width: 769px) {
    #mens-coming-soon-{{ section.id }} .vellor-coming-soon__grid {
      grid-template-columns: 1fr 1fr;
      min-height: 70vh;
    }
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__text-col {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    order: 2;
  }

  @media (min-width: 769px) {
    #mens-coming-soon-{{ section.id }} .vellor-coming-soon__text-col {
      padding: 4rem;
      order: 1;
    }
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__text-inner {
    max-width: 440px;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__label {
    display: block;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999999;
    margin-bottom: 1.5rem;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__heading {
    font-family: 'Cormorant Garamond', 'Times New Roman', serif;
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 300;
    line-height: 1.15;
    margin: 0 0 1.25rem;
    color: #F2F2F2;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__description {
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #999999;
    margin-bottom: 2rem;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__form-row {
    display: flex;
    gap: 0;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__input {
    flex: 1;
    padding: 0.9rem 1rem;
    background: transparent;
    border: none;
    color: #F2F2F2;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.8rem;
    outline: none;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__input::placeholder {
    color: #666;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__button {
    padding: 0.9rem 1.5rem;
    background-color: #F2F2F2;
    color: #0A0A0A;
    border: none;
    font-family: 'Inter', 'Helvetica Neue', sans-serif;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__button:hover {
    background-color: #ddd;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__image-col {
    position: relative;
    overflow: hidden;
    min-height: 400px;
    order: 1;
  }

  @media (min-width: 769px) {
    #mens-coming-soon-{{ section.id }} .vellor-coming-soon__image-col {
      order: 2;
    }
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #mens-coming-soon-{{ section.id }} .vellor-coming-soon__placeholder {
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>

{% schema %}
{
  "name": "Coming Soon",
  "tag": "section",
  "class": "vellor-section-coming-soon",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Coming Soon"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Men's Collection"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>The same 14oz heavyweight fleece. The same garment-dyed softness. The same tonal V embroidery. Oversized hoodies, tapered joggers, and coordinated sets — built for him. Sign up to be the first to know.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Input Placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Notify Me"
    }
  ],
  "presets": [
    {
      "name": "Coming Soon",
      "category": "VELLOR"
    }
  ]
}
{% endschema %}
